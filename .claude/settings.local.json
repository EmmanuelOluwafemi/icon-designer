{
  "permissions": {
    "allow": [
      "Bash(cd:*)",
      "Bash(pnpm test:*)",
      "Bash(gh issue:*)",
      "Bash(npx vitest:*)",
      "Bash(pnpm typecheck:*)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash(git commit)",
        "hooks": [
          {
            "type": "command",
            "command": "pnpm run lint && pnpm test"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write",
        "hooks": [
          {
            "type": "command",
            "command": "echo 'File written: $CLAUDE_FILE_PATH'"
          }
        ]
      }
    ]
  }
}
